{
  "name": "lumen-player",
  "productName": "Lumen",
  "version": "0.1.5",
  "description": "A luminous home for your videos — a modern Windows video player.",
  "main": "out/main/index.js",
  "type": "module",
  "author": "Lumen",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "dev:web": "vite --config vite.web.config.ts",
    "start": "electron-vite preview",
    "build": "npm run typecheck && electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "dist": "electron-vite build && electron-builder --win --publish never"
  },
  "dependencies": {
    "lucide-react": "latest",
    "motion": "^12.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^38.0.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "latest",
    "typescript": "^5.6.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  },
  "build": {
    "appId": "app.lumen.player",
    "productName": "Lumen",
    "directories": { "output": "release" },
    "files": ["out/**"],
    "win": {
      "target": ["nsis"],
      "fileAssociations": [
        { "ext": "mp4", "name": "Video" },
        { "ext": "mkv", "name": "Video" },
        { "ext": "webm", "name": "Video" },
        { "ext": "mov", "name": "Video" },
        { "ext": "avi", "name": "Video" },
        { "ext": "m4v", "name": "Video" }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Lumen",
      "deleteAppDataOnUninstall": false
    }
  }
}
